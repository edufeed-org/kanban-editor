{
  "name": "nostr-cli",
  "version": "0.0.1",
  "scripts": {
    "dev": "vite dev",
    "build:site": "vite build",
    "build": "vite build && npm run prepack",
    "preview": "pnpm run build:site && sirv build --single --host 127.0.0.1 --port 4173",
    "preview:ci": "pnpm run build:site && sirv build --single --host 0.0.0.0 --port 4173",
    "prepare": "svelte-kit sync || echo ''",
    "prepack": "svelte-kit sync && svelte-package && publint",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test:unit": "vitest",
    "test": "npm run test:unit -- --run && npm run test:e2e",
    "test:e2e": "playwright test"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "svelte": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.36.0",
    "@iconify/json": "^2.2.395",
    "@iconify/tailwind4": "^1.0.6",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.544.0",
    "@playwright/test": "^1.55.1",
    "@sveltejs/adapter-static": "^3.0.9",
    "@sveltejs/kit": "^2.43.2",
    "@sveltejs/package": "^2.5.4",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@sveltejs/vite-plugin-svelte-inspector": "^5.0.1",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.18",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@vitest/browser": "^3.2.4",
    "bits-ui": "^2.11.5",
    "clsx": "^2.1.1",
    "eslint": "^9.36.0",
    "eslint-plugin-svelte": "^3.12.4",
    "formsnap": "^2.0.1",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.0",
    "mdsvex": "^0.12.6",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.55.1",
    "publint": "^0.3.13",
    "sirv-cli": "^3.0.1",
    "svelte": "^5.39.5",
    "svelte-check": "^4.3.2",
    "svelte-sonner": "^1.0.5",
    "sveltekit-superforms": "^2.27.2",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss": "^4.1.13",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "^7.1.7",
    "vite-plugin-devtools-json": "^1.0.0",
    "vitest": "^3.2.4",
    "vitest-browser-svelte": "^1.1.0"
  },
  "keywords": [
    "svelte"
  ],
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@edufeed-org/oer-finder-plugin",
      "@edufeed-org/oer-finder-api-client"
    ],
    "overrides": {
      "nostr-tools": "~2.14.2",
      "@nostr-dev-kit/ndk": "^2.14.2",
      "@edufeed-org/oer-finder-api-client": "github:edufeed-org/oer-finder-plugin#v0.1.1&path:packages/oer-finder-api-client"
    },
    "ignoredBuiltDependencies": [
      "svelte-preprocess"
    ]
  },
  "dependencies": {
    "@edufeed-org/oer-finder-plugin": "github:edufeed-org/oer-finder-plugin#v0.1.1&path:packages/oer-finder-plugin",
    "@nostr-dev-kit/ndk": "2.14.2",
    "@nostr-dev-kit/svelte": "^2.0.8",
    "jsoncrush": "^1.1.8",
    "lucide-svelte": "^0.546.0",
    "oidc-client-ts": "^3.3.0",
    "svelte-dnd-action": "^0.9.65",
    "svelte-persisted-store": "^0.12.0",
    "zod": "^4.1.12"
  }
}